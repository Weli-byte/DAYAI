# =============================================================================
# AI Service — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
APP_LOG_LEVEL=debug

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:4000"]

# ── Backend service (internal communication) ──────────────────────────────────
BACKEND_URL=http://localhost:4000

# ── Model storage ─────────────────────────────────────────────────────────────
# Where downloaded/cached models are stored (Docker volume in production)
MODEL_CACHE_DIR=/tmp/model-cache

# ── Torch / CUDA ──────────────────────────────────────────────────────────────
DEVICE=cpu
# Set to "cuda" when GPU is available — Sprint 5 inference will respect this
