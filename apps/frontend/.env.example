# =============================================================================
# Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# NEXT_PUBLIC_ prefix makes variables available in the browser bundle.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Decentralized AI Marketplace"

# ── API ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Monad Blockchain (filled in Sprint 5) ────────────────────────────────────
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://10143.rpc.thirdweb.com
NEXT_PUBLIC_MONAD_BLOCK_EXPLORER=https://monad-testnet.socialscan.io

# ── IPFS (filled in Sprint 5) ─────────────────────────────────────────────────
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_DEVTOOLS=true
