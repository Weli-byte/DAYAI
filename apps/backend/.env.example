# =============================================================================
# Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://marketplace:marketplace_dev@localhost:5432/marketplace_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# ── AI Service ─────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=30000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs

# ── Swagger ────────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true

# ── IPFS / Pinata ──────────────────────────────────────────────────────────────
PINATA_JWT=your_pinata_jwt_here
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Blockchain (Monad) ─────────────────────────────────────────────────────────
MONAD_RPC_URL=https://10143.rpc.thirdweb.com
BACKEND_PRIVATE_KEY=your_private_key_here_without_0x
NFT_CONTRACT_ADDRESS=0x_deployed_contract_address
