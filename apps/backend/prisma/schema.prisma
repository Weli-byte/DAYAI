// =============================================================================
// Prisma Schema — Decentralized AI Model Marketplace
//
// Sprint 2 Milestone 1: AI Model Registry & Core Marketplace
// Models: User, Category, Tag, AIModel, ModelVersion, AIModelTag
//
// Commands:
//   pnpm prisma:migrate  → create + apply migration
//   pnpm prisma:generate → regenerate Prisma Client typings
//   pnpm prisma:studio   → open Prisma Studio GUI
//   pnpm prisma:seed     → run seed script
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Uncomment when using a connection pooler (PgBouncer, Supabase, etc.):
  // directUrl = env("DATABASE_DIRECT_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Framework {
  PYTORCH
  TENSORFLOW
  SKLEARN
  ONNX
  JAX
  OTHER
}

enum ModelStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// =============================================================================
// Models
// =============================================================================

/// Platform user — wallet address filled in a future milestone
model User {
  id        String    @id @default(cuid())
  username  String    @unique @db.VarChar(50)
  email     String?   @unique @db.VarChar(255)
  bio       String?   @db.Text
  avatar    String?   @db.VarChar(500)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  models          AIModel[]
  profile         UserProfile?
  reviews         Review[]
  ratings         Rating[]
  favorites       Favorite[]
  analyticsEvents AnalyticsEvent[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

/// Taxonomy category for organising AI models
model Category {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  models AIModel[]

  @@index([slug])
  @@map("categories")
}

/// Free-form tag for flexible model classification
model Tag {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models AIModelTag[]

  @@index([slug])
  @@map("tags")
}

/// Core AI Model entity — the primary marketplace asset
model AIModel {
  id          String      @id @default(cuid())
  title       String      @db.VarChar(200)
  description String?     @db.Text
  framework   Framework   @default(OTHER)
  status      ModelStatus @default(DRAFT)
  license     String?     @db.VarChar(100)
  ownerId     String
  categoryId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  owner         User             @relation(fields: [ownerId], references: [id])
  category      Category?        @relation(fields: [categoryId], references: [id])
  tags          AIModelTag[]
  versions      ModelVersion[]
  inferenceLogs InferenceLog[]
  reviews       Review[]
  ratings       Rating[]
  favorites     Favorite[]
  analyticsEvents AnalyticsEvent[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([status])
  @@index([framework])
  @@index([deletedAt])
  // Full-text search index on title for fast ILIKE queries
  @@index([title])
  @@map("ai_models")
}

/// Immutable version snapshot of an AI Model
model ModelVersion {
  id          String   @id @default(cuid())
  modelId     String
  version     String   @db.VarChar(20)
  changelog   String?  @db.Text
  // IPFS
  fileCid     String?  @db.VarChar(200)
  metadataCid String?  @db.VarChar(200)
  // Legacy alias kept for backward compat
  ipfsHash    String?  @db.VarChar(200)
  // File info
  fileSize    BigInt?
  sha256      String?  @db.VarChar(64)
  // Blockchain
  nftTokenId  String?  @db.VarChar(78)
  txHash      String?  @db.VarChar(66)
  // Owner wallet at time of mint
  ownerAddress String? @db.VarChar(42)
  isLatest    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  model AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, version])
  @@index([modelId])
  @@index([nftTokenId])
  @@map("model_versions")
}

/// Upload job tracking — short-lived, cleaned up after 7 days
model UploadJob {
  id          String   @id @default(cuid())
  modelId     String?
  versionId   String?
  status      UploadJobStatus @default(PENDING)
  stage       String?  @db.VarChar(50)
  fileCid     String?  @db.VarChar(200)
  metadataCid String?  @db.VarChar(200)
  nftTokenId  String?  @db.VarChar(78)
  txHash      String?  @db.VarChar(66)
  errorMessage String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([modelId])
  @@index([status])
  @@map("upload_jobs")
}

enum UploadJobStatus {
  PENDING
  UPLOADING_FILE
  UPLOADING_METADATA
  MINTING
  COMPLETED
  FAILED
}

/// Many-to-many join table: AIModel ↔ Tag
model AIModelTag {
  modelId String
  tagId   String

  model AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  tag   Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([modelId, tagId])
  @@map("ai_model_tags")
}

enum InferenceStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model InferenceLog {
  id              String          @id @default(cuid())
  modelId         String
  model           AIModel         @relation(fields: [modelId], references: [id])
  walletAddress   String          @db.VarChar(42)
  prompt          String          @db.Text
  output          String?         @db.Text
  status          InferenceStatus @default(PENDING)
  tokensUsed      Int?
  inferenceTimeMs Int?
  errorMessage    String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([walletAddress])
  @@index([modelId])
  @@index([createdAt])
  @@map("inference_logs")
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String?  @db.VarChar(100)
  website       String?  @db.VarChar(200)
  twitter       String?  @db.VarChar(100)
  github        String?  @db.VarChar(100)
  walletAddress String?  @unique @db.VarChar(42)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_profiles")
}

model Review {
  id        String   @id @default(cuid())
  modelId   String
  model     AIModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([modelId])
  @@index([userId])
  @@map("reviews")
}

model Rating {
  id        String   @id @default(cuid())
  modelId   String
  model     AIModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int      @db.Integer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modelId, userId])
  @@index([modelId])
  @@index([userId])
  @@map("ratings")
}

model Favorite {
  id        String   @id @default(cuid())
  modelId   String
  model     AIModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([modelId, userId])
  @@index([userId])
  @@map("favorites")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String   @db.VarChar(50)
  modelId   String?
  model     AIModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([modelId])
  @@index([createdAt])
  @@map("analytics_events")
}
