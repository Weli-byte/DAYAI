// =============================================================================
// Prisma Schema — Decentralized AI Model Marketplace
//
// Sprint 1: Infrastructure only — datasource + client configured, no models yet.
// Sprint 5+: AI Model, User, Listing, Transaction, Contribution tables.
//
// Commands:
//   pnpm prisma:migrate  → create + apply migration
//   pnpm prisma:generate → regenerate Prisma Client typings
//   pnpm prisma:studio   → open Prisma Studio GUI
//   pnpm prisma:seed     → run seed script
// =============================================================================

generator client {
  provider = "prisma-client-js"
  // Enables type-safe query results and improves DX.
  // Remove if Prisma Client is not used in the edge runtime.
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Connection pooling via PgBouncer (Supabase, Railway, etc.)
  // Uncomment directUrl when using a connection pooler:
  // directUrl = env("DATABASE_DIRECT_URL")
}

