# =============================================================================
# Decentralized AI Marketplace — .gitignore
# Covers: Node.js, Python, Docker, VSCode, JetBrains, Solidity, and more.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.test.example
*.pem
*.key
*.p12
*.pfx
secrets/
.secret

# -----------------------------------------------------------------------------
# Node.js / JavaScript / TypeScript
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
lerna-debug.log*
.npm/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
*.tsbuildinfo
*.d.ts.map

# -----------------------------------------------------------------------------
# Test & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
.vitest/

# -----------------------------------------------------------------------------
# TurboRepo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# Python / FastAPI / AI Services
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
.python-version
*.egg-info/
.eggs/
dist/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
*.pyc
*.pyo
poetry.lock
Pipfile.lock
.pdm.toml
.pdm-python
__pypackages__/

# AI / ML model artifacts
*.pkl
*.pickle
*.h5
*.hdf5
*.pt
*.pth
*.onnx
*.pb
models/
checkpoints/
wandb/
mlruns/
.mlflow/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Solidity / Smart Contracts
# -----------------------------------------------------------------------------
artifacts/
cache/
typechain/
typechain-types/
deployments/localhost/
deployments/hardhat/
.openzeppelin/unknown-*.json

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
*.dockerignore

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
npm-debug.log
yarn-debug.log
yarn-error.log

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# VSCode
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace

# -----------------------------------------------------------------------------
# JetBrains (WebStorm, IntelliJ, PyCharm, etc.)
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.idea_modules/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
.cache/
tmp/
temp/
.history/
.changeset/
!.changeset/.gitkeep
