# =============================================================================
# Decentralized AI Marketplace — .gitignore
# Covers: Node.js · pnpm · Python · Docker · VS Code · JetBrains
#         macOS · Windows · Linux · env files · logs · builds · coverage
# =============================================================================

# ── Environment & Secrets (NEVER commit) ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.pnp.*

# ── Build Outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
*.tsbuildinfo

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# ── TurboRepo ─────────────────────────────────────────────────────────────────
.turbo/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
.Python
venv/
.venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pyc

# ML model artifacts
*.pkl
*.h5
*.pt
*.pth
*.onnx
# Only ignore root-level ML model binary directory, not source code modules
/models/
checkpoints/

# ── Solidity / Smart Contracts ────────────────────────────────────────────────
artifacts/
cache/
typechain-types/
deployments/localhost/
deployments/hardhat/

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Linux ────────────────────────────────────────────────────────────────────
*~

# ── VS Code ──────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# ── JetBrains (WebStorm, IntelliJ, PyCharm) ──────────────────────────────────
.idea/
*.iml
*.iws
*.ipr

# ── Miscellaneous ─────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
.cache/
tmp/
