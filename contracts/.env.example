# =============================================================================
# Contracts — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env — it is git-ignored.
# =============================================================================

# ── Deployer wallet private key ───────────────────────────────────────────────
# The account that signs and pays for deployment transactions.
# Use a dedicated testnet-only wallet — NEVER your main wallet.
PRIVATE_KEY=

# ── Monad Testnet ─────────────────────────────────────────────────────────────
# Public RPC endpoint (no auth required for testnet).
MONAD_RPC_URL=https://10143.rpc.thirdweb.com

# Chain ID for Monad Testnet
CHAIN_ID=10143

# Block explorer base URL
BLOCK_EXPLORER=https://monad-testnet.socialscan.io

# API key for contract verification on the block explorer (if supported)
ETHERSCAN_API_KEY=

# ── Optional: Gas reporting ───────────────────────────────────────────────────
# Set to "true" to enable gas cost table after each `pnpm test` run
REPORT_GAS=false

# CoinMarketCap API key for USD gas cost conversion in gas reports
COINMARKETCAP_API_KEY=
