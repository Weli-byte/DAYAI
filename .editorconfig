# EditorConfig: ensures consistent coding style across all editors and IDEs.
# https://editorconfig.org
# Supported by VS Code, JetBrains, Vim, Neovim, Emacs, and many others.

root = true

# ── Default (all files) ──────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# ── Markdown ─────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false

# ── Python ───────────────────────────────────────────────────────────────────
[*.{py,pyi}]
indent_size = 4

# ── Solidity ─────────────────────────────────────────────────────────────────
[*.sol]
indent_size = 4

# ── Makefiles (tabs required) ─────────────────────────────────────────────────
[Makefile]
indent_style = tab
